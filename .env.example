# ============================================================
# SENTINAL — Central Environment Configuration
# ============================================================
# Copy this file to .env and fill in your real values.
#   cp .env.example .env
#
# NEVER commit your actual .env file to Git.
# ============================================================

# ── SYSTEM ───────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ── NETWORK ──────────────────────────────────────────────────
HOST=0.0.0.0
PUBLIC_URL=http://localhost

# ── DATABASE ─────────────────────────────────────────────────
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/sentinel
ATLAS_SEARCH_INDEX=attackevents_search

# ── SERVICE PORTS ────────────────────────────────────────────
GATEWAY_PORT=3000
DETECTION_PORT=8002
PCAP_PORT=8003
NEXUS_PORT=8004
DASHBOARD_PORT=5173

# ── INTERNAL SERVICE URLs ────────────────────────────────────
DETECTION_URL=http://localhost:8002
PCAP_URL=http://localhost:8003
NEXUS_URL=http://localhost:8004
GATEWAY_URL=http://localhost:3000

# ── SECURITY ─────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret_string
API_SECRET=change_me_to_another_long_random_secret_string

# ── AI SERVICES ──────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── GEO-IP THREAT INTELLIGENCE ───────────────────────────────
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# ── PCAP PROCESSOR — Detection Thresholds ────────────────────
BATCH_SIZE=50
HTTP_TIMEOUT=10.0
FLOW_TIMEOUT=120
MAX_PCAP_SIZE_MB=500
PORT_SCAN_THRESHOLD=15
SYN_FLOOD_PPS_THRESHOLD=100
DDOS_PPS_THRESHOLD=500
DNS_AMP_RATIO_THRESHOLD=5.0
ICMP_FLOOD_PPS_THRESHOLD=50
BRUTE_FORCE_THRESHOLD=10
LOG_DIR=logs

# ── DEPLOYMENT ───────────────────────────────────────────────
ENVIRONMENT=local
REGION=us-east-1
