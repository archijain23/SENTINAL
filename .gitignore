# =============================================================================
# SENTINAL — .gitignore
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# SECRETS & ENVIRONMENT — NEVER COMMIT
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.production
.env.staging
.env.development
!.env.example
!.env.backup/

# ─────────────────────────────────────────────────────────────────────────────
# NODE.JS
# ─────────────────────────────────────────────────────────────────────────────
node_modules/
dist/
build/
.npm/

# ─────────────────────────────────────────────────────────────────────────────
# PYTHON
# ─────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
.venv/
env/
.env/
ENV/
pip-wheel-metadata/
.pip/
*.egg-info/
*.egg
dist/
*.pyi
.pytest_cache/
.tox/
.mypy_cache/
.dmypy.json

# ─────────────────────────────────────────────────────────────────────────────
# LOGS
# ─────────────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
backend/logs/
services/*/logs/

# ─────────────────────────────────────────────────────────────────────────────
# PM2 RUNTIME FILES
# ─────────────────────────────────────────────────────────────────────────────
ecosystem.config.local.js
.pm2/

# ─────────────────────────────────────────────────────────────────────────────
# UPLOADED FILES (PCAP, temp uploads)
# ─────────────────────────────────────────────────────────────────────────────
uploads/
*.pcap
*.pcapng
tmp/

# ─────────────────────────────────────────────────────────────────────────────
# TEST COVERAGE
# ─────────────────────────────────────────────────────────────────────────────
coverage/
.coverage
.coverage.*
htmlcov/
junit.xml
coverage.xml

# ─────────────────────────────────────────────────────────────────────────────
# OS & EDITOR
# ─────────────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*~
.idea/
.vscode/
*.suo
*.user
*.sublime-project
*.sublime-workspace
*.tmp
*.bak
*.swp
*.swo
*.orig

# ─────────────────────────────────────────────────────────────────────────────
# DOCKER (future)
# ─────────────────────────────────────────────────────────────────────────────
.docker/
docker-compose.override.yml
